    gt_NorthmanSettlementSpawn = TriggerCreate("gt_NorthmanSettlementSpawn_Func");
    TriggerEnable(gt_NorthmanSettlementSpawn, false);
    TriggerAddEventTimePeriodic(gt_NorthmanSettlementSpawn, 90.0, c_timeGame);
}

