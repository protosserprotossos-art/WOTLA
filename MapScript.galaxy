    gt_ActivateNurn = TriggerCreate("gt_ActivateNurn_Func");
    TriggerEnable(gt_ActivateNurn, false);
    TriggerAddEventUnitBehaviorChange(gt_ActivateNurn, null, "EventCooldown", c_unitBehaviorChangeDestroy);
}

//--------------------------------------------------------------------------------------------------
// Trigger: Nurn (Good)
//--------------------------------------------------------------------------------------------------
bool gt_NurnGood_Func (bool testConds, bool runActions) {
    // Variable Declarations
    unit lv_spawner;
    point lv_point;
    string lv_research;

    // Automatic Variable Declarations
    // Variable Initialization
    lv_spawner = gv_nurn;
    lv_point = PointFromId(877709145);
    lv_research = "IthilienUpgradeSpawn";

    // Conditions
    if (testConds) {
        if (!((UnitIsAlive(lv_spawner) == true))) {
            return false;
        }

        if (!((PlayerGetPropertyInt(UnitGetOwner(lv_spawner), c_playerPropSuppliesUsed) <= PlayerGetPropertyInt(UnitGetOwner(lv_spawner), c_playerPropSuppliesMade)))) {
            return false;
        }

        if (!((UnitGetOwner(lv_spawner) != 0))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    Wait(0.25, c_timeGame);
    gf_Createunit(1, "Vulture", lv_spawner, lv_point);
    gf_Createunit(1, "MengskHellion", lv_spawner, lv_point);
    gf_Createunit(1, "Predator", lv_spawner, lv_point);
    if ((TechTreeUpgradeCount(UnitGetOwner(lv_spawner), lv_research, c_techCountCompleteOnly) >= 4)) {
        gf_Createunit(1, "DarkTemplarShakuras", lv_spawner, lv_point);
        gf_Createunit(1, "StalkerPurifier", lv_spawner, lv_point);
        gf_Createunit(1, "MengskHellion", lv_spawner, lv_point);
    }

    if ((TechTreeUpgradeCount(UnitGetOwner(lv_spawner), lv_research, c_techCountCompleteOnly) >= 3)) {
        gf_Createunit(2, "MengskHellion", lv_spawner, lv_point);
        gf_Createunit(1, "Vulture", lv_spawner, lv_point);
    }

    if ((TechTreeUpgradeCount(UnitGetOwner(lv_spawner), lv_research, c_techCountCompleteOnly) >= 2)) {
        gf_Createunit(2, "StalkerPurifier", lv_spawner, lv_point);
        gf_Createunit(1, "Predator", lv_spawner, lv_point);
    }

    if ((TechTreeUpgradeCount(UnitGetOwner(lv_spawner), lv_research, c_techCountCompleteOnly) >= 1)) {
        gf_Createunit(1, "DarkTemplarShakuras", lv_spawner, lv_point);
        gf_Createunit(1, "Marine", lv_spawner, lv_point);
    }

    return true;
}

