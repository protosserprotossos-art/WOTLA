// Trigger: Activate Corsair Lond Daer(ship)
//--------------------------------------------------------------------------------------------------
bool gt_ActivateCorsairLondDaership_Func (bool testConds, bool runActions) {
    // Variable Declarations
    int lv_index;

    // Automatic Variable Declarations
    unitgroup auto4532F149_g;
    int auto4532F149_u;
    unit auto4532F149_var;
    const int auto37F25AE3_ae = 16;
    const int auto37F25AE3_ai = 1;

    // Variable Initialization

    // Conditions
    if (testConds) {
        if (!((UnitGetType(EventUnit()) == "CorsairEncampmentLefnui2"))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    auto4532F149_g = UnitGroup("PhotonCannon", c_playerAny, RegionFromId(80), UnitFilter(0, 0, (1 << c_targetFilterMissile), (1 << (c_targetFilterDead - 32)) | (1 << (c_targetFilterHidden - 32))), 0);
    auto4532F149_u = UnitGroupCount(auto4532F149_g, c_unitCountAll);
    for (;; auto4532F149_u -= 1) {
        auto4532F149_var = UnitGroupUnitFromEnd(auto4532F149_g, auto4532F149_u);
        if (auto4532F149_var == null) { break; }
        UnitKill(auto4532F149_var);
    }
    UnitIssueOrder(EventUnit(), OrderTargetingPoint(AbilityCommand("ColonistShipLand2", 0), PointFromId(764104611)), c_orderQueueAddToEnd);
    UnitWaitUntilIdle(EventUnit(), true);
    SoundPlayForPlayer(SoundLink("Corsairsfromthesouth", -1), c_maxPlayers, PlayerGroupAll(), 75.0, 0.0);
    UIDisplayMessage(PlayerGroupAll(), c_messageAreaSubtitle, StringExternal("Param/Value/E7AEE9AE"));
    libNtve_gf_RescueUnit(EventUnit(), gv_corsairTriggeringUnitOwner, true);
    lv_index = 1;
    for ( ; ( (auto37F25AE3_ai >= 0 && lv_index <= auto37F25AE3_ae) || (auto37F25AE3_ai < 0 && lv_index >= auto37F25AE3_ae) ) ; lv_index += auto37F25AE3_ai ) {
        gf_CreateCannon(UnitGetOwner(UnitFromId(1767098372)), PointFromName(("CorsairLondDaerCannon" + IntToString(lv_index))));
    }
    TriggerEnable(gt_CorsairLondDaer, true);
    TriggerEnable(TriggerGetCurrent(), false);
    return true;
}

