        if ((TechTreeUpgradeCount(UnitGetOwner(lv_spawner), "DolAmrothUpgradespawn4", c_techCountCompleteOnly) == 1) && (TechTreeUpgradeCount(UnitGetOwner(lv_spawner), "HorselordsOfDolAmroth", c_techCountCompleteOnly) == 1)) {
