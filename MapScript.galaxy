//--------------------------------------------------------------------------------------------------
// Trigger: Master Spy Respawn
//--------------------------------------------------------------------------------------------------
bool gt_MasterSpyRespawn_Func (bool testConds, bool runActions) {
    // Automatic Variable Declarations
    // Actions
    if (!runActions) {
        return true;
    }

    if ((UnitIsAlive(gv_eastGondorSpy) == false)) {
        libNtve_gf_CreateUnitsWithDefaultFacing(1, "Observer", 0, gv_itemEastGondor, PointFromId(1956332581));
        gv_eastGondorSpy = UnitLastCreated();
    }

    if ((UnitIsAlive(gv_elvesSpy) == false)) {
        libNtve_gf_CreateUnitsWithDefaultFacing(1, "Observer", 0, gv_itemElves, PointFromId(283882455));
        gv_elvesSpy = UnitLastCreated();
    }

    if ((UnitIsAlive(gv_arnorSpy) == false)) {
        libNtve_gf_CreateUnitsWithDefaultFacing(1, "Observer", 0, gv_itemArnor, PointFromId(1102867604));
        gv_arnorSpy = UnitLastCreated();
    }

    if ((UnitIsAlive(gv_westGondorSpy) == false)) {
        libNtve_gf_CreateUnitsWithDefaultFacing(1, "Observer", 0, gv_itemWestGondor, PointFromId(886977154));
        gv_westGondorSpy = UnitLastCreated();
    }

    if ((UnitIsAlive(gv_mordorSpy) == false)) {
        libNtve_gf_CreateUnitsWithDefaultFacing(1, "Observer", 0, gv_itemMordor, PointFromId(162865192));
        gv_mordorSpy = UnitLastCreated();
    }

    if ((UnitIsAlive(gv_evilmenSpy) == false)) {
        libNtve_gf_CreateUnitsWithDefaultFacing(1, "Observer", 0, gv_itemEvilMen, PointFromId(1980932493));
        gv_evilmenSpy = UnitLastCreated();
    }

    if ((UnitIsAlive(gv_mistySpy) == false)) {
        libNtve_gf_CreateUnitsWithDefaultFacing(1, "Observer", 0, gv_itemMistyMountains, PointFromId(1207796644));
        gv_mistySpy = UnitLastCreated();
    }

    if ((UnitIsAlive(gv_dwarvesSpy) == false)) {
        libNtve_gf_CreateUnitsWithDefaultFacing(1, "Observer", 0, gv_itemDwarves, PointFromId(486097910));
        gv_dwarvesSpy = UnitLastCreated();
    }

    if ((UnitIsAlive(gv_easterlingsSpy) == false)) {
        libNtve_gf_CreateUnitsWithDefaultFacing(1, "Observer", 0, gv_itemEasterlings, PointFromId(936611018));
        gv_easterlingsSpy = UnitLastCreated();
    }

    if ((UnitIsAlive(gv_northmanSpy) == false) && (gv_factionIsOnNorthmen == true)) {
        libNtve_gf_CreateUnitsWithDefaultFacing(1, "Observer", 0, gv_itemNorthmen, PointFromId(419586109));
        gv_northmanSpy = UnitLastCreated();
    }

    if ((UnitIsAlive(gv_gwathlorimSpy) == false) && (gv_factionIsOnNorthmen == true)) {
        libNtve_gf_CreateUnitsWithDefaultFacing(1, "Observer", 0, gv_itemSouthArnor, PointFromId(581331990));
        gv_gwathlorimSpy = UnitLastCreated();
    }

    if ((UnitIsAlive(gv_lindonSpy) == false) && (gv_factionIsOnLindon == true)) {
        libNtve_gf_CreateUnitsWithDefaultFacing(1, "Observer", 0, gv_itemLindon, PointFromId(1983257430));
        gv_lindonSpy = UnitLastCreated();
    }

    if ((UnitIsAlive(gv_southronsSpy) == false) && (gv_factionIsOnSouthron == true)) {
        libNtve_gf_CreateUnitsWithDefaultFacing(1, "Observer", 0, gv_itemSouthron, PointFromId(1062406593));
        gv_southronsSpy = UnitLastCreated();
    }

    if ((UnitIsAlive(gv_hoarddaleSpy) == false) && (gv_factionIsOnHoarddale == true)) {
        libNtve_gf_CreateUnitsWithDefaultFacing(1, "Observer", 0, gv_itemHoardDale, PointFromId(1259028994));
        gv_hoarddaleSpy = UnitLastCreated();
    }

    return true;
}

