    gt_CorsairLondDaer = TriggerCreate("gt_CorsairLondDaer_Func");
    TriggerEnable(gt_CorsairLondDaer, false);
    TriggerAddEventTimePeriodic(gt_CorsairLondDaer, 90.0, c_timeGame);
}

