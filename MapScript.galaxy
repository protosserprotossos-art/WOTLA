void gt_Scatha_Init () {
    gt_Scatha = TriggerCreate("gt_Scatha_Func");
    TriggerEnable(gt_Scatha, false);
    TriggerAddEventTimePeriodic(gt_Scatha, 90.0, c_timeGame);
}

