//--------------------------------------------------------------------------------------------------
// Trigger: FactionIsOn
//--------------------------------------------------------------------------------------------------
bool gt_FactionIsOn_Func (bool testConds, bool runActions) {
    // Automatic Variable Declarations
    // Actions
    if (!runActions) {
        return true;
    }

    if ((gv_factionIsOnSouthArnor == true)) {
        gf_Createunit(1, "Odin", UnitFromId(1731438873), PointFromId(1627549480));
    }

    if ((gv_factionIsOnHoarddale == true)) {
        gf_Createunit(1, "QueenMP", UnitFromId(1920784909), PointFromId(1259028994));
        gv_grashkul = UnitLastCreated();
    }

    if ((gv_factionIsOnLindon == true)) {
        gf_Createunit(1, "ArbiterMP", UnitFromId(677747402), PointFromId(927171715));
    }

    if ((gv_factionIsOnSouthron == true)) {
        gf_Createunit(1, "KerriganGhostLab", UnitFromId(1767098372), PointFromId(1062406593));
        gf_Createunit(1, "ArbiterMP", UnitFromId(1164482133), PointFromId(1143397629));
    }

    if ((gv_factionIsOnWestGondor == true)) {
        gf_Createunit(1, "Raven", UnitFromId(126626611), PointFromId(1632910664));
        gf_Createunit(1, "MengskSiegeTank", UnitFromId(1919917573), PointFromId(316080415));
        gf_Createunit(1, "Tosh", UnitFromId(490175528), PointFromId(1011198778));
    }
    else {
        gf_Createunit(1, "Tosh", UnitFromId(439325741), PointFromId(1102867604));
        gf_Createunit(1, "Raven", UnitFromId(1325808467), PointFromId(1956332581));
    }
    if ((gv_factionIsOnNorthmen == true)) {
        gf_Createunit(1, "Brandvig", UnitFromId(2112326322), PointFromId(419586109));
        gf_Createunit(1, "Brynulf", UnitFromId(2112326322), PointFromId(419586109));
        gf_Createunit(1, "ArbiterMP", UnitFromId(1325808467), PointFromId(1956332581));
    }

    return true;
}

//--------------------------------------------------------------------------------------------------
void gt_FactionIsOn_Init () {
    gt_FactionIsOn = TriggerCreate("gt_FactionIsOn_Func");
    TriggerAddEventMapInit(gt_FactionIsOn);
}

