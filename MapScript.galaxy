    gt_DruwaithLaur = TriggerCreate("gt_DruwaithLaur_Func");
    TriggerEnable(gt_DruwaithLaur, false);
    TriggerAddEventTimePeriodic(gt_DruwaithLaur, 90.0, c_timeGame);
}

