//--------------------------------------------------------------------------------------------------
// Trigger: Ai checker
//--------------------------------------------------------------------------------------------------
bool gt_Aichecker_Func (bool testConds, bool runActions) {
    // Automatic Variable Declarations
    // Actions
    if (!runActions) {
        return true;
    }

    if ((PlayerType(gv_itemEastGondor) == c_playerTypeComputer)) {
        TriggerEnable(gt_AICanResearchEastGondor, true);
        gv_playernumber -= 1;
    }

    if ((PlayerType(gv_itemElves) == c_playerTypeComputer)) {
        TriggerEnable(gt_AICanResearchElves, true);
        gv_playernumber -= 1;
    }

    if ((PlayerType(gv_itemArnor) == c_playerTypeComputer)) {
        TriggerEnable(gt_AICanResearchArnor, true);
        gv_playernumber -= 1;
    }

    if ((PlayerType(gv_itemWestGondor) == c_playerTypeComputer)) {
        TriggerEnable(gt_AICanResearchWestGondor, true);
        gv_playernumber -= 1;
    }

    if ((PlayerType(gv_itemMordor) == c_playerTypeComputer)) {
        TriggerEnable(gt_AICanResearchMordor, true);
        gv_playernumber -= 1;
    }

    if ((PlayerType(gv_itemEvilMen) == c_playerTypeComputer)) {
        TriggerEnable(gt_AICanResearchEvilmen, true);
        gv_playernumber -= 1;
    }

    if ((PlayerType(gv_itemMistyMountains) == c_playerTypeComputer)) {
        TriggerEnable(gt_AICanResearchMistyMountain, true);
        gv_playernumber -= 1;
    }

    if ((PlayerType(gv_itemDwarves) == c_playerTypeComputer)) {
        TriggerEnable(gt_AICanResearchDwarves, true);
        gv_playernumber -= 1;
    }

    if ((PlayerType(gv_itemEasterlings) == c_playerTypeComputer)) {
        TriggerEnable(gt_AICanResearchEasterlings, true);
        gv_playernumber -= 1;
    }

    return true;
}

