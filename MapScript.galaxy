//--------------------------------------------------------------------------------------------------
// Trigger: Turn Gray Mountains Beacon On
//--------------------------------------------------------------------------------------------------
bool gt_TurnGrayMountainsBeaconOn_Func (bool testConds, bool runActions) {
    // Automatic Variable Declarations
    // Actions
    if (!runActions) {
        return true;
    }

    if ((gv_grayMountainsActivated == false) && (UnitIsAlive(gv_scatha) == false) && (UnitIsAlive(UnitFromId(2081578249)) == false)) {
        if ((UnitIsAlive(gv_grayMountainsBeacon) == false)) {
            libNtve_gf_CreateUnitsWithDefaultFacing(1, "GrayMountains", c_unitCreateIgnorePlacement, 0, PointFromId(1063644599));
            gv_grayMountainsBeacon = UnitLastCreated();
        }

        TriggerEnable(gt_ActivateGrayMountains, true);
    }
    else {
        if ((UnitIsAlive(gv_grayMountainsBeacon) == true)) {
            UnitKill(gv_grayMountainsBeacon);
        }

        TriggerEnable(gt_ActivateGrayMountains, false);
    }
    return true;
}

//--------------------------------------------------------------------------------------------------
void gt_TurnGrayMountainsBeaconOn_Init () {
    gt_TurnGrayMountainsBeaconOn = TriggerCreate("gt_TurnGrayMountainsBeaconOn_Func");
    TriggerAddEventUnitDied(gt_TurnGrayMountainsBeaconOn, UnitRefFromUnit(UnitFromId(2081578249)));
    TriggerAddEventUnitDied(gt_TurnGrayMountainsBeaconOn, UnitRefFromVariable("gv_scatha"));
    TriggerAddEventUnitBehaviorChange(gt_TurnGrayMountainsBeaconOn, null, "EventCooldown", c_unitBehaviorChangeDestroy);
}

//--------------------------------------------------------------------------------------------------
// Trigger: Activate Gray Mountains
//--------------------------------------------------------------------------------------------------
bool gt_ActivateGrayMountains_Func (bool testConds, bool runActions) {
    // Automatic Variable Declarations
    // Conditions
    if (testConds) {
        if (!((PlayerGetPropertyInt(UnitGetOwner(EventUnit()), c_playerPropMinerals) >= 5500))) {
            return false;
        }

        if (!(((UnitGetType(EventUnit()) == "Loki") || ((UnitGetType(EventUnit()) == "Warbot"))))) {
            return false;
        }

        if (!((libNtve_gf_UnitInRegion(EventUnit(), RegionFromId(64)) == true))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    gf_ClearRegionOfStatic(RegionFromId(65));
    PlayerModifyPropertyInt(UnitGetOwner(EventUnit()), c_playerPropMinerals, c_playerPropOperSubtract, 5500);
    libNtve_gf_CreateUnitsWithDefaultFacing(1, "PlatformConnector", c_unitCreateIgnorePlacement, EventPlayer(), PointFromId(177108751));
    gv_grayMountainsActivated = true;
    gv_grayMountains = UnitLastCreated();
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(11494293));
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(1528322312));
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(2040128086));
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(113462942));
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(851410576));
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(2126726601));
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(1025847438));
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(772509106));
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(883225692));
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(1541815973));
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(478530918));
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(1011847903));
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(1412185534));
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(1118014459));
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(433516127));
    UIDisplayMessage(PlayerGroupAll(), c_messageAreaSubtitle, StringExternal("Param/Value/E077D488"));
    SoundPlayForPlayer(SoundLink("Eventtriggering", -1), c_maxPlayers, PlayerGroupAll(), 75.0, 0.0);
    UnitKill(gv_grayMountainsBeacon);
    UnitKill(gv_scathaBeacon);
    TriggerEnable(gt_GrayMountains, true);
    TriggerEnable(TriggerGetCurrent(), false);
    return true;
}

