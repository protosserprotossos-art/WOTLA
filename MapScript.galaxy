//--------------------------------------------------------------------------------------------------
// Trigger: Invasion Activated
//--------------------------------------------------------------------------------------------------
bool gt_InvasionActivated_Func (bool testConds, bool runActions) {
    // Variable Declarations
    int lv_index;

    // Automatic Variable Declarations
    const int auto2EBF26AB_ae = 10;
    const int auto2EBF26AB_ai = 1;
    const int auto1CFD3263_ae = 10;
    const int auto1CFD3263_ai = 1;
    const int autoF18591DC_ae = 2;
    const int autoF18591DC_ai = 1;
    const int autoA12F86F1_ae = 5;
    const int autoA12F86F1_ai = 1;
    const int auto879284ED_ae = 2;
    const int auto879284ED_ai = 1;
    const int autoCE2F4084_ae = 10;
    const int autoCE2F4084_ai = 1;
    const int auto799F901B_ae = 10;
    const int auto799F901B_ai = 1;
    const int auto4B2E1A85_ae = 2;
    const int auto4B2E1A85_ai = 1;
    const int autoA2E174B9_ae = 5;
    const int autoA2E174B9_ai = 1;
    const int autoC4F8E47B_ae = 2;
    const int autoC4F8E47B_ai = 1;

    // Variable Initialization

    // Conditions
    if (testConds) {
        if (!(((EventPlayer() == UnitGetOwner(UnitFromId(761806837))) || (EventPlayer() == UnitGetOwner(gv_dunharrowCaptured))))) {
            return false;
        }

        if (!(((TechTreeUpgradeCount(UnitGetOwner(UnitFromId(761806837)), "InvasionOfCalenardhon", c_techCountCompleteOnly) == 1) || (TechTreeUpgradeCount(UnitGetOwner(gv_dunharrowCaptured), "InvasionOfCalenardhon", c_techCountCompleteOnly) == 1)))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    if ((gf_OwnerOfUnitIsInEvil(EventUnit()) == true) && (UnitIsAlive(UnitFromId(1325808467)) == true)) {
        libNtve_gf_CreateUnitsWithDefaultFacing(1, "ZealotAiur", c_unitCreateIgnorePlacement, UnitGetOwner(UnitFromId(1325808467)), PointFromId(1956332581));
        gv_calenardhonInvasionHero = UnitLastCreated();
        UnitGroupAdd(gv_invasionGroup, UnitLastCreated());
        UnitBehaviorAdd(UnitLastCreated(), "Uncommandable", UnitFromId(1565330970), 1);
        UnitBehaviorAdd(UnitLastCreated(), "Siegeingunit", UnitFromId(1565330970), 1);
        UnitBehaviorAddPlayer(UnitLastCreated(), "ArtanisStasisField", 0, 1);
        lv_index = 1;
        for ( ; ( (auto2EBF26AB_ai >= 0 && lv_index <= auto2EBF26AB_ae) || (auto2EBF26AB_ai < 0 && lv_index >= auto2EBF26AB_ae) ) ; lv_index += auto2EBF26AB_ai ) {
            libNtve_gf_CreateUnitsWithDefaultFacing(1, "Marine", c_unitCreateIgnorePlacement, UnitGetOwner(UnitFromId(1325808467)), PointFromId(1956332581));
            UnitGroupAdd(gv_invasionGroup, UnitLastCreated());
