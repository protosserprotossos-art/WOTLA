//--------------------------------------------------------------------------------------------------
bool gt_ActivateElostorin_Func (bool testConds, bool runActions) {
    // Automatic Variable Declarations
    // Conditions
    if (testConds) {
        if (!((PlayerGetPropertyInt(UnitGetOwner(EventUnit()), c_playerPropMinerals) >= 5000))) {
            return false;
        }

        if (!(((UnitGetType(EventUnit()) == "ScienceVessel") || (UnitGetType(EventUnit()) == "Zeratul")))) {
            return false;
        }

        if (!((libNtve_gf_UnitInRegion(EventUnit(), RegionFromId(26)) == true))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    PlayerModifyPropertyInt(UnitGetOwner(EventUnit()), c_playerPropMinerals, c_playerPropOperSubtract, 5000);
    libNtve_gf_CreateUnitsWithDefaultFacing(1, "Elostirion", c_unitCreateIgnorePlacement, EventPlayer(), PointFromId(489593578));
    gv_elostorin = UnitLastCreated();
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(653029679));
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(383443053));
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(2110834432));
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(598881714));
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(414643876));
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(1358865408));
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(788947148));
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(1421045991));
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(2137809664));
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(1165412270));
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(1319052091));
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(2136303011));
    SoundPlayForPlayer(SoundLink("Eventtriggering", -1), c_maxPlayers, PlayerGroupAll(), 75.0, 0.0);
    UnitKill(gv_elostorinBeacon);
    if ((UnitGetOwner(gv_elostorin) == gv_itemArnor)) {
        UIDisplayMessage(PlayerGroupAll(), c_messageAreaSubtitle, StringExternal("Param/Value/38CCEFF6"));
        TriggerEnable(gt_ElostorinHuman, true);
    }
    else {
        UIDisplayMessage(PlayerGroupAll(), c_messageAreaSubtitle, StringExternal("Param/Value/786F30C6"));
        TriggerEnable(gt_ElstorinElves, true);
    }
    TriggerEnable(TriggerGetCurrent(), false);
    return true;
}

