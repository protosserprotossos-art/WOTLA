    // Variable Declarations
    int lv_index;

    // Automatic Variable Declarations
    const int auto0D18DCB5_ae = 11;
    const int auto0D18DCB5_ai = 1;

    // Variable Initialization

    // Conditions
    if (testConds) {
        if (!((PlayerGetPropertyInt(UnitGetOwner(EventUnit()), c_playerPropMinerals) >= 3500))) {
            return false;
        }

        if (!(((UnitGetOwner(EventUnit()) == gv_itemArnor) || (UnitGetOwner(EventUnit()) == gv_itemSouthArnor)))) {
            return false;
        }

        if (!((libNtve_gf_UnitInRegion(EventUnit(), RegionFromId(85)) == true))) {
