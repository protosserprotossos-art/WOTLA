//--------------------------------------------------------------------------------------------------
// Trigger: Form Dwarven Colation
//--------------------------------------------------------------------------------------------------
bool gt_FormDwarvenColation_Func (bool testConds, bool runActions) {
    // Automatic Variable Declarations
    // Conditions
    if (testConds) {
        if (!((TechTreeUpgradeCount(UnitGetOwner(gv_redDwarvesEncampment), "FormaDwarvenColation", c_techCountCompleteOnly) == 1))) {
            return false;
        }

        if (!((EventPlayer() == UnitGetOwner(gv_redDwarvesEncampment)))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    UIDisplayMessage(PlayerGroupAll(), c_messageAreaSubtitle, StringExternal("Param/Value/5CFA5AC5"));
    TimerStart(gv_dwarvenColationTimer, 300.0, false, c_timeGame);
    TimerWindowCreate(gv_dwarvenColationTimer, StringExternal("Param/Value/E172E3AD"), false, false);
    gv_dwarvenColationTimerWindow = TimerWindowLastCreated();
    TimerWindowSetStyle(gv_dwarvenColationTimerWindow, c_timerWindowStyleHorizontalTitleTime, false);
    TimerWindowShow(gv_dwarvenColationTimerWindow, PlayerGroupAll(), true);
    TimerWindowShowBorder(gv_dwarvenColationTimerWindow, true);
    TriggerEnable(TriggerGetCurrent(), false);
    Wait(300.0, c_timeGame);
    TimerWindowDestroy(gv_dwarvenColationTimerWindow);
    if ((UnitIsAlive(gv_redDwarvesEncampment) == true)) {
        libNtve_gf_CreateUnitsWithDefaultFacing(1, "DwarvenLordOfRedMountains", c_unitCreateIgnorePlacement, UnitGetOwner(gv_redDwarvesEncampment), PointFromId(769943264));
        libNtve_gf_CreateUnitsWithDefaultFacing(5, "ImmortalShakuras", c_unitCreateIgnorePlacement, UnitGetOwner(gv_redDwarvesEncampment), PointFromId(769943264));
        libNtve_gf_CreateUnitsWithDefaultFacing(5, "ThorAP", c_unitCreateIgnorePlacement, UnitGetOwner(gv_redDwarvesEncampment), PointFromId(769943264));
        libNtve_gf_CreateUnitsWithDefaultFacing(5, "HellionTank", c_unitCreateIgnorePlacement, UnitGetOwner(gv_redDwarvesEncampment), PointFromId(769943264));
        libNtve_gf_CreateUnitsWithDefaultFacing(5, "DominionKillTeam", c_unitCreateIgnorePlacement, UnitGetOwner(gv_redDwarvesEncampment), PointFromId(769943264));
        libNtve_gf_CreateUnitsWithDefaultFacing(5, "Pygalisk", c_unitCreateIgnorePlacement, UnitGetOwner(gv_redDwarvesEncampment), PointFromId(769943264));
        libNtve_gf_CreateUnitsWithDefaultFacing(20, "Marauder", c_unitCreateIgnorePlacement, UnitGetOwner(gv_redDwarvesEncampment), PointFromId(769943264));
        libNtve_gf_CreateUnitsWithDefaultFacing(20, "Firebat", c_unitCreateIgnorePlacement, UnitGetOwner(gv_redDwarvesEncampment), PointFromId(769943264));
        UIDisplayMessage(PlayerGroupAll(), c_messageAreaSubtitle, StringExternal("Param/Value/ECA35592"));
    }
    else {
        UIDisplayMessage(PlayerGroupAll(), c_messageAreaSubtitle, StringExternal("Param/Value/EED2BCD8"));
        libNtve_gf_CreateUnitsWithDefaultFacing(2, "ImmortalShakuras", c_unitCreateIgnorePlacement, UnitGetOwner(gv_redDwarvesEncampment), PointFromId(769943264));
        libNtve_gf_CreateUnitsWithDefaultFacing(5, "Marauder", c_unitCreateIgnorePlacement, UnitGetOwner(gv_redDwarvesEncampment), PointFromId(769943264));
        libNtve_gf_CreateUnitsWithDefaultFacing(5, "Firebat", c_unitCreateIgnorePlacement, UnitGetOwner(gv_redDwarvesEncampment), PointFromId(769943264));
    }
    return true;
}

