//--------------------------------------------------------------------------------------------------
bool gt_Identifers_Func (bool testConds, bool runActions) {
    // Variable Declarations
    int lv_index;

    // Automatic Variable Declarations
    const int auto254A92E7_ae = 15;
    const int auto254A92E7_ai = 1;

    // Variable Initialization

    // Actions
    if (!runActions) {
        return true;
    }

    lv_index = 1;
    for ( ; ( (auto254A92E7_ai >= 0 && lv_index <= auto254A92E7_ae) || (auto254A92E7_ai < 0 && lv_index >= auto254A92E7_ae) ) ; lv_index += auto254A92E7_ai ) {
        if ((gf_PlayerIsInEvil(lv_index) == true)) {
            libNtve_gf_SetUpgradeLevelForPlayer(lv_index, "Evilidentifer", 1);
        }

        if ((gf_PlayerIsInGood(lv_index) == true)) {
            libNtve_gf_SetUpgradeLevelForPlayer(lv_index, "Goodidentifer", 1);
        }

    }
    return true;
}

