    // Automatic Variable Declarations
    // Actions
    if (!runActions) {
        return true;
    }

    Wait(300.0, c_timeGame);
    libNtve_gf_SetUpgradeLevelForPlayer(UnitGetOwner(gv_morgoth), "eclipseofhopeWeakening", 1);
    Wait(300.0, c_timeGame);
    libNtve_gf_SetUpgradeLevelForPlayer(UnitGetOwner(gv_morgoth), "eclipseofhopeWeakening", 2);
    Wait(300.0, c_timeGame);
    libNtve_gf_SetUpgradeLevelForPlayer(UnitGetOwner(gv_morgoth), "eclipseofhopeWeakening", 3);
    return true;
}

