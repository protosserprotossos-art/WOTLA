//--------------------------------------------------------------------------------------------------
// Trigger: Activate Redwood Crossing
//--------------------------------------------------------------------------------------------------
bool gt_ActivateRedwoodCrossing_Func (bool testConds, bool runActions) {
    // Automatic Variable Declarations
    // Conditions
    if (testConds) {
        if (!((PlayerGetPropertyInt(UnitGetOwner(EventUnit()), c_playerPropMinerals) >= 3000))) {
            return false;
        }

        if (!(((UnitGetType(EventUnit()) == "Dehaka") || (UnitGetType(EventUnit()) == "Warbot") || (UnitGetType(EventUnit()) == "Brandvig")))) {
            return false;
        }

        if (!((libNtve_gf_UnitInRegion(EventUnit(), RegionFromId(70)) == true))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    PlayerModifyPropertyInt(UnitGetOwner(EventUnit()), c_playerPropMinerals, c_playerPropOperSubtract, 3000);
    libNtve_gf_CreateUnitsWithDefaultFacing(1, "Reactor", c_unitCreateIgnorePlacement, EventPlayer(), PointFromId(457425896));
    gv_redwoodCrossing = UnitLastCreated();
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(1427357324));
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(1053716169));
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(1915748927));
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(1833746747));
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(1063027368));
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(1625093467));
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(1722436884));
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(995962102));
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(920611120));
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(1525343422));
    SoundPlayForPlayer(SoundLink("Eventtriggering", -1), c_maxPlayers, PlayerGroupAll(), 75.0, 0.0);
    UnitKill(gv_redwoodCrossingbeacon);
    if (((UnitGetOwner(EventUnit()) == gv_itemDwarves) || (UnitGetOwner(EventUnit()) == gv_itemNorthmen))) {
        libNtve_gf_SetUpgradeLevelForPlayer(UnitGetOwner(EventUnit()), "RedwoodCrossingDwarves", 1);
        UIDisplayMessage(PlayerGroupAll(), c_messageAreaSubtitle, StringExternal("Param/Value/A03CE8B1"));
    }
    else {
        libNtve_gf_SetUpgradeLevelForPlayer(UnitGetOwner(EventUnit()), "RedwoodCrossingEasterlings", 1);
        UIDisplayMessage(PlayerGroupAll(), c_messageAreaSubtitle, StringExternal("Param/Value/4AB40CAA"));
    }
    TriggerEnable(gt_RedwoodCrossing, true);
    TriggerEnable(TriggerGetCurrent(), false);
    return true;
}

