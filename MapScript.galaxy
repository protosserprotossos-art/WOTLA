// Trigger: Activate Dale
//--------------------------------------------------------------------------------------------------
bool gt_ActivateDale_Func (bool testConds, bool runActions) {
    // Automatic Variable Declarations
    // Conditions
    if (testConds) {
        if (!((PlayerGetPropertyInt(UnitGetOwner(EventUnit()), c_playerPropMinerals) >= 4500))) {
            return false;
        }

        if (!(((UnitGetType(EventUnit()) == "VorazunChampion") || ((UnitGetType(EventUnit()) == "Dehaka"))))) {
            return false;
        }

        if (!((libNtve_gf_UnitInRegion(EventUnit(), RegionFromId(66)) == true))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    gf_ClearRegionOfStatic(RegionFromId(67));
    PlayerModifyPropertyInt(UnitGetOwner(EventUnit()), c_playerPropMinerals, c_playerPropOperSubtract, 4500);
    libNtve_gf_CreateUnitsWithDefaultFacing(1, "DaleCaptured", c_unitCreateIgnorePlacement, EventPlayer(), PointFromId(1358166332));
    gv_daleActivated = true;
    gv_daleCaptured = UnitLastCreated();
