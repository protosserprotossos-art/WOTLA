//--------------------------------------------------------------------------------------------------
// Trigger: Rapid Orc Breeding spawning
//--------------------------------------------------------------------------------------------------
bool gt_RapidOrcBreedingspawning_Func (bool testConds, bool runActions) {
    // Automatic Variable Declarations
    // Conditions
    if (testConds) {
        if (!(((TechTreeUpgradeCount(gv_itemHoardDale, "RapidOrcBreeding", c_techCountQueuedOrBetter) >= 1) || (TechTreeUpgradeCount(gv_itemEvilMen, "RapidOrcBreeding", c_techCountQueuedOrBetter) >= 1)))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    if ((UnitGetOwner(UnitFromId(1920784909)) != 0) && (PlayerGetPropertyInt(UnitGetOwner(UnitFromId(1920784909)), c_playerPropSuppliesUsed) <= PlayerGetPropertyInt(UnitGetOwner(UnitFromId(1920784909)), c_playerPropSuppliesMade)) && (UnitIsAlive(UnitFromId(1920784909)) == true)) {
        gf_Createunit(2, "StukovInfestedTerran", UnitFromId(1920784909), PointFromId(1259028994));
        gf_Createunit(2, "Zergling", UnitFromId(1920784909), PointFromId(1259028994));
    }

    if ((UnitGetOwner(UnitFromId(1521351733)) != 0) && (PlayerGetPropertyInt(UnitGetOwner(UnitFromId(1521351733)), c_playerPropSuppliesUsed) <= PlayerGetPropertyInt(UnitGetOwner(UnitFromId(1521351733)), c_playerPropSuppliesMade)) && (UnitIsAlive(UnitFromId(1521351733)) == true)) {
        gf_Createunit(2, "StukovInfestedTerran", UnitFromId(1521351733), PointFromId(513821936));
        gf_Createunit(2, "Zergling", UnitFromId(1521351733), PointFromId(513821936));
    }

