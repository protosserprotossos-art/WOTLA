//--------------------------------------------------------------------------------------------------
bool gt_ActivateDunharrow_Func (bool testConds, bool runActions) {
    // Automatic Variable Declarations
    // Conditions
    if (testConds) {
        if (!((PlayerGetPropertyInt(UnitGetOwner(EventUnit()), c_playerPropMinerals) >= 4000))) {
            return false;
        }

        if (!(((UnitGetType(EventUnit()) == "Raven") || (UnitGetType(EventUnit()) == "MothershipAiur06") || (UnitGetType(EventUnit()) == "Brandvig")))) {
            return false;
        }

        if (!((libNtve_gf_UnitInRegion(EventUnit(), RegionFromId(69)) == true))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    gf_ClearRegionOfStatic(RegionFromId(68));
    PlayerModifyPropertyInt(UnitGetOwner(EventUnit()), c_playerPropMinerals, c_playerPropOperSubtract, 4000);
    libNtve_gf_CreateUnitsWithDefaultFacing(1, "DunharrowGood", c_unitCreateIgnorePlacement, EventPlayer(), PointFromId(1694840715));
    gv_dunharrowActivated = true;
    gv_dunharrowCaptured = UnitLastCreated();
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(314761708));
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(726248012));
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(834680145));
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(1712008199));
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(1280042930));
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(1803951412));
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(3880686));
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(1193425205));
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(1732383657));
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(1329973237));
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(814051443));
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(1400630132));
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(1168918149));
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(35577877));
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(105608452));
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(441338397));
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(584373912));
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(2144324948));
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(1522981457));
    UIDisplayMessage(PlayerGroupAll(), c_messageAreaSubtitle, StringExternal("Param/Value/E3A69FB0"));
    UnitKill(gv_dunharrowBeaconcaptured);
    SoundPlayForPlayer(SoundLink("Eventtriggering", -1), c_maxPlayers, PlayerGroupAll(), 75.0, 0.0);
    TriggerEnable(gt_DunharrowCaptured, true);
    TriggerEnable(TriggerGetCurrent(), false);
    return true;
}

