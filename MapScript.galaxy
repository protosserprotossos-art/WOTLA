                }
            }
        }
        if ((TechTreeUpgradeCount(UnitGetOwner(lv_spawner), "DolAmrothUpgradespawn5", c_techCountCompleteOnly) == 1) && (TechTreeUpgradeCount(UnitGetOwner(lv_spawner), "HorselordsOfDolAmroth", c_techCountCompleteOnly) == 1)) {
