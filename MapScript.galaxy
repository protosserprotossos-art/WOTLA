void gt_FieldOfSilverlode_Init () {
    gt_FieldOfSilverlode = TriggerCreate("gt_FieldOfSilverlode_Func");
    TriggerEnable(gt_FieldOfSilverlode, false);
    TriggerAddEventTimePeriodic(gt_FieldOfSilverlode, 90.0, c_timeGame);
}

