    gt_ActivateRedwoodCrossing = TriggerCreate("gt_ActivateRedwoodCrossing_Func");
    TriggerAddEventUnitBehaviorChange(gt_ActivateRedwoodCrossing, null, "EventCooldown", c_unitBehaviorChangeDestroy);
}

//--------------------------------------------------------------------------------------------------
// Trigger: Redwood Crossing
//--------------------------------------------------------------------------------------------------
bool gt_RedwoodCrossing_Func (bool testConds, bool runActions) {
    // Variable Declarations
    unit lv_spawner;
    point lv_point;

    // Automatic Variable Declarations
    // Variable Initialization
    lv_spawner = gv_redwoodCrossing;
    lv_point = PointFromId(1609570478);

    // Conditions
    if (testConds) {
        if (!((UnitIsAlive(lv_spawner) == true))) {
            return false;
        }

        if (!((PlayerGetPropertyInt(UnitGetOwner(lv_spawner), c_playerPropSuppliesUsed) <= PlayerGetPropertyInt(UnitGetOwner(lv_spawner), c_playerPropSuppliesMade)))) {
            return false;
        }

        if (!((UnitGetOwner(lv_spawner) != 0))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    Wait(0.25, c_timeGame);
    if ((TechTreeUpgradeCount(UnitGetOwner(lv_spawner), "RedwoodCrossingDwarves", c_techCountCompleteOnly) >= 1)) {
        gf_Createunit(1, "Hellion", lv_spawner, lv_point);
        gf_Createunit(1, "VikingAssault", lv_spawner, lv_point);
        gf_Createunit(1, "Marauder", lv_spawner, lv_point);
        gf_Createunit(2, "Firebat", lv_spawner, lv_point);
    }

    if ((TechTreeUpgradeCount(UnitGetOwner(lv_spawner), "RedwoodCrossingEasterlings", c_techCountCompleteOnly) >= 1)) {
        gf_Createunit(1, "Goliath", lv_spawner, lv_point);
        gf_Createunit(1, "MengskDiamondback", lv_spawner, lv_point);
        gf_Createunit(1, "MengskMarine", lv_spawner, lv_point);
        gf_Createunit(2, "DarkTemplarTaldarim", lv_spawner, lv_point);
    }

    return true;
}

