    if (true) {
        libNtve_gf_CreateUnitsWithDefaultFacing(1, "PhotonCannon", c_unitCreateIgnorePlacement, lp_player, lp_point);
        libNtve_gf_RescueUnit(UnitLastCreated(), lp_player, true);
        UnitBehaviorAddPlayer(UnitLastCreated(), "ArtanisStasisField", 0, 1);
    }
    else {

    }
}

void gf_ClearRegionOfStatic (region lp_regionDestroy) {
    // Variable Declarations
    unitgroup lv_clearUnitGroup;

    // Automatic Variable Declarations
    unitgroup autoEEEED3DC_g;
    int autoEEEED3DC_u;
    unit autoEEEED3DC_var;

    // Variable Initialization
    lv_clearUnitGroup = UnitGroupEmpty();

    // Implementation
    lv_clearUnitGroup = UnitGroup("PhotonCannon", c_playerAny, lp_regionDestroy, UnitFilter(0, 0, (1 << c_targetFilterMissile), (1 << (c_targetFilterDead - 32)) | (1 << (c_targetFilterHidden - 32))), 0);
    autoEEEED3DC_g = lv_clearUnitGroup;
    autoEEEED3DC_u = UnitGroupCount(autoEEEED3DC_g, c_unitCountAll);
    for (;; autoEEEED3DC_u -= 1) {
        autoEEEED3DC_var = UnitGroupUnitFromEnd(autoEEEED3DC_g, autoEEEED3DC_u);
        if (autoEEEED3DC_var == null) { break; }
        UnitKill(autoEEEED3DC_var);
    }
}

bool gf_PlayerIsInGood (int lp_player) {
    // Automatic Variable Declarations
    // Implementation
    if (((lp_player == gv_itemWestGondor) || (lp_player == gv_itemDwarves) || (lp_player == gv_itemEastGondor) || (lp_player == gv_itemArnor) || (lp_player == gv_itemElves) || (lp_player == gv_itemSouthArnor) || (lp_player == gv_itemLindon) || (lp_player == gv_itemNorthmen))) {
        return true;
    }
    else {
        return false;
    }
}

bool gf_PlayerIsInEvil (int lp_player) {
    // Automatic Variable Declarations
    // Implementation
    if (((lp_player == gv_itemEvilMen) || (lp_player == gv_itemMordor) || (lp_player == gv_itemMistyMountains) || (lp_player == gv_itemEasterlings) || (lp_player == gv_itemHoardDale) || (lp_player == gv_itemSouthron))) {
        return true;
    }
    else {
        return false;
    }
}

bool gf_OwnerOfUnitIsInGood (unit lp_triggeringUnit) {
    // Automatic Variable Declarations
    // Implementation
    if (((UnitGetOwner(lp_triggeringUnit) == gv_itemWestGondor) || (UnitGetOwner(lp_triggeringUnit) == gv_itemDwarves) || (UnitGetOwner(lp_triggeringUnit) == gv_itemEastGondor) || (UnitGetOwner(lp_triggeringUnit) == gv_itemArnor) || (UnitGetOwner(lp_triggeringUnit) == gv_itemElves) || (UnitGetOwner(lp_triggeringUnit) == gv_itemSouthArnor) || (UnitGetOwner(lp_triggeringUnit) == gv_itemLindon) || (UnitGetOwner(lp_triggeringUnit) == gv_itemNorthmen))) {
        return true;
    }
    else {
        return false;
    }
}

bool gf_OwnerOfUnitIsInEvil (unit lp_triggeringUnit) {
    // Automatic Variable Declarations
    // Implementation
    if (((UnitGetOwner(lp_triggeringUnit) == gv_itemEvilMen) || (UnitGetOwner(lp_triggeringUnit) == gv_itemMordor) || (UnitGetOwner(lp_triggeringUnit) == gv_itemMistyMountains) || (UnitGetOwner(lp_triggeringUnit) == gv_itemEasterlings) || (UnitGetOwner(lp_triggeringUnit) == gv_itemHoardDale) || (UnitGetOwner(lp_triggeringUnit) == gv_itemSouthron))) {
        return true;
    }
    else {
        return false;
    }
}

//--------------------------------------------------------------------------------------------------
// Trigger: Hero Death
//--------------------------------------------------------------------------------------------------
bool gt_HeroDeath_Func (bool testConds, bool runActions) {
    // Automatic Variable Declarations
    // Conditions
    if (testConds) {
        if (!((UnitTypeTestAttribute(UnitGetType(EventUnit()), c_unitAttributeHeroic) == true))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    libNtve_gf_CreatePingFacingAngle(PlayerGroupAll(), "PingObjective", UnitGetPosition(EventUnit()), Color(100.00, 0.00, 0.00), 8.0, 270.0);
    if ((UnitGetOwner(libNtve_gf_KillingUnit()) != UnitGetOwner(EventUnit()))) {
        UIDisplayMessage(PlayerGroupAll(), c_messageAreaDebug, ((StringToText("") + (StringToText("") + TextWithColor(UnitGetName(EventUnit()), libNtve_gf_ConvertPlayerColorToColor(PlayerGetColorIndex(EventPlayer(), false))))) + (StringExternal("Param/Value/C44720CC") + TextWithColor(UnitGetName(libNtve_gf_KillingUnit()), libNtve_gf_ConvertPlayerColorToColor(PlayerGetColorIndex(UnitGetOwner(libNtve_gf_KillingUnit()), false))))));
        SoundPlayForPlayer(SoundLink("HeroDead", -1), c_maxPlayers, PlayerGroupAll(), 100.0, 0.0);
    }

    if ((gf_OwnerOfUnitIsInGood(EventUnit()) == true)) {
        TriggerExecute(gt_IncreaseIsildurWrathCount, true, false);
    }

    return true;
}

//--------------------------------------------------------------------------------------------------
void gt_HeroDeath_Init () {
    gt_HeroDeath = TriggerCreate("gt_HeroDeath_Func");
    TriggerAddEventUnitDied(gt_HeroDeath, null);
}

//--------------------------------------------------------------------------------------------------
// Trigger: Spawner Death
//--------------------------------------------------------------------------------------------------
bool gt_SpawnerDeath_Func (bool testConds, bool runActions) {
    // Automatic Variable Declarations
    // Conditions
    if (testConds) {
        if (!((UnitTypeTestAttribute(UnitGetType(EventUnit()), c_unitAttributeStructure) == true))) {
            return false;
        }

        if (!((UnitGetType(EventUnit()) != "PhotonCannon"))) {
            return false;
        }

        if (!((UnitGetType(EventUnit()) != "SentryGun"))) {
            return false;
        }

        if (!((UnitGetType(EventUnit()) != "SentryGunUnderground"))) {
            return false;
        }

        if (!((UnitGetType(EventUnit()) != "SpiderMine"))) {
            return false;
        }

        if (!((UnitGetType(EventUnit()) != "SpiderMineBurrowed"))) {
            return false;
        }

        if (!((UnitGetType(EventUnit()) != "Pylon"))) {
            return false;
        }

        if (!((UnitGetType(EventUnit()) != "PointDefenseDrone"))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    libNtve_gf_CreatePingFacingAngle(PlayerGroupAll(), "PingObjective", UnitGetPosition(EventUnit()), Color(100.00, 0.00, 0.00), 8.0, 270.0);
    if ((UnitGetOwner(libNtve_gf_KillingUnit()) != UnitGetOwner(EventUnit()))) {
        UIDisplayMessage(PlayerGroupAll(), c_messageAreaDebug, ((StringToText("") + (StringToText("") + TextWithColor(UnitGetName(EventUnit()), libNtve_gf_ConvertPlayerColorToColor(PlayerGetColorIndex(EventPlayer(), false))))) + (StringExternal("Param/Value/F408D6A8") + TextWithColor(UnitGetName(libNtve_gf_KillingUnit()), libNtve_gf_ConvertPlayerColorToColor(PlayerGetColorIndex(UnitGetOwner(libNtve_gf_KillingUnit()), false))))));
    }

    return true;
}

//--------------------------------------------------------------------------------------------------
void gt_SpawnerDeath_Init () {
    gt_SpawnerDeath = TriggerCreate("gt_SpawnerDeath_Func");
    TriggerAddEventUnitDied(gt_SpawnerDeath, null);
}

//--------------------------------------------------------------------------------------------------
// Trigger: Disable Hero Death Temporayily
//--------------------------------------------------------------------------------------------------
bool gt_DisableHeroDeathTemporayily_Func (bool testConds, bool runActions) {
    // Automatic Variable Declarations
    // Actions
    if (!runActions) {
        return true;
    }

    TriggerEnable(gt_HeroDeath, false);
    Wait(1.0, c_timeGame);
    TriggerEnable(gt_HeroDeath, true);
    return true;
}

//--------------------------------------------------------------------------------------------------
void gt_DisableHeroDeathTemporayily_Init () {
    gt_DisableHeroDeathTemporayily = TriggerCreate("gt_DisableHeroDeathTemporayily_Func");
}

//--------------------------------------------------------------------------------------------------
// Trigger: Morgoth Death
//--------------------------------------------------------------------------------------------------
bool gt_MorgothDeath_Func (bool testConds, bool runActions) {
    // Automatic Variable Declarations
    // Conditions
    if (testConds) {
        if (!((UnitGetOwner(libNtve_gf_KillingUnit()) != 0))) {
            return false;
        }

        if (!((UnitGetType(EventUnit()) == "HybridBehemoth"))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    libNtve_gf_CreatePingFacingAngle(PlayerGroupAll(), "PingObjective", UnitGetPosition(EventUnit()), Color(100.00, 0.00, 0.00), 8.0, 270.0);
    if ((UnitGetOwner(libNtve_gf_KillingUnit()) != UnitGetOwner(EventUnit()))) {
        UIDisplayMessage(PlayerGroupAll(), c_messageAreaSubtitle, StringExternal("Param/Value/3940AC5C"));
        SoundPlayForPlayer(SoundLink("HeroDead", -1), c_maxPlayers, PlayerGroupAll(), 100.0, 0.0);
    }

    TriggerEnable(TriggerGetCurrent(), false);
    return true;
}

//--------------------------------------------------------------------------------------------------
void gt_MorgothDeath_Init () {
    gt_MorgothDeath = TriggerCreate("gt_MorgothDeath_Func");
    TriggerEnable(gt_MorgothDeath, false);
    TriggerAddEventUnitDied(gt_MorgothDeath, UnitRefFromVariable("gv_morgoth"));
}

//--------------------------------------------------------------------------------------------------
// Trigger: Ring mechanic 2
//--------------------------------------------------------------------------------------------------
bool gt_Ringmechanic2_Func (bool testConds, bool runActions) {
    // Automatic Variable Declarations
    // Actions
    if (!runActions) {
        return true;
    }

    if ((UnitGetType(libNtve_gf_KillingUnit()) == "KerriganGhostLabUnarmed")) {
        UnitBehaviorAdd(libNtve_gf_KillingUnit(), "OneRing", UnitFromId(856187551), 1);
        gv_ringBearer = libNtve_gf_KillingUnit();
        UIDisplayMessage(PlayerGroupAll(), c_messageAreaSubtitle, StringExternal("Param/Value/B8174036"));
        libNtve_gf_KillDoodadsInRegion(RegionFromId(60), null);
    }
    else if ((UnitGetType(libNtve_gf_KillingUnit()) == "HERC")) {
        UnitBehaviorAdd(libNtve_gf_KillingUnit(), "OneRing", UnitFromId(856187551), 1);
        gv_ringBearer = libNtve_gf_KillingUnit();
        UIDisplayMessage(PlayerGroupAll(), c_messageAreaSubtitle, StringExternal("Param/Value/BE8F619C"));
    }
    else if ((UnitGetType(EventUnit()) == "HERC")) {
        UIDisplayMessage(PlayerGroupAll(), c_messageAreaSubtitle, StringExternal("Param/Value/F0C37BD9"));
    }
    else if (true) {
        UnitBehaviorAdd(libNtve_gf_KillingUnit(), "OneRing", UnitFromId(856187551), 1);
        gv_ringBearer = libNtve_gf_KillingUnit();
        UIDisplayMessage(PlayerGroupAll(), c_messageAreaSubtitle, (StringExternal("Param/Value/C4E56E93") + UnitGetName(libNtve_gf_KillingUnit())));
    }
    return true;
}

