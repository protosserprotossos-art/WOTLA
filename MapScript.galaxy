    PlayerModifyPropertyInt(UnitGetOwner(EventUnit()), c_playerPropMinerals, c_playerPropOperSubtract, 3500);
    libNtve_gf_CreateUnitsWithDefaultFacing(1, "EredLuinEncampment", c_unitCreateIgnorePlacement, EventPlayer(), PointFromId(1187629969));
    gv_eredLuin = UnitLastCreated();
    UnitKill(UnitFromId(1449417490));
    lv_index = 1;
    for ( ; ( (auto0D18DCB5_ai >= 0 && lv_index <= auto0D18DCB5_ae) || (auto0D18DCB5_ai < 0 && lv_index >= auto0D18DCB5_ae) ) ; lv_index += auto0D18DCB5_ai ) {
        gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromName(("EredLuinCannon" + IntToString(lv_index))));
    }
    UIDisplayMessage(PlayerGroupAll(), c_messageAreaSubtitle, StringExternal("Param/Value/718FA498"));
    SoundPlayForPlayer(SoundLink("Eventtriggering", -1), c_maxPlayers, PlayerGroupAll(), 75.0, 0.0);
    UnitKill(gv_eredLuinBeacon);
    TriggerEnable(gt_EredLuin, true);
    TriggerEnable(TriggerGetCurrent(), false);
    return true;
}

