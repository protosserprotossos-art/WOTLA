    gt_ElostorinHuman = TriggerCreate("gt_ElostorinHuman_Func");
    TriggerEnable(gt_ElostorinHuman, false);
    TriggerAddEventTimePeriodic(gt_ElostorinHuman, 90.0, c_timeGame);
}

