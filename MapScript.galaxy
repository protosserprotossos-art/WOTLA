void gt_AInormaldifficulty_Init () {
    gt_AInormaldifficulty = TriggerCreate("gt_AInormaldifficulty_Func");
    TriggerEnable(gt_AInormaldifficulty, false);
    TriggerAddEventTimePeriodic(gt_AInormaldifficulty, 15.0, c_timeGame);
}

