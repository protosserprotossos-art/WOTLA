//--------------------------------------------------------------------------------------------------
// Trigger: Activate Last Bridge
//--------------------------------------------------------------------------------------------------
bool gt_ActivateLastBridge_Func (bool testConds, bool runActions) {
    // Automatic Variable Declarations
    // Conditions
    if (testConds) {
        if (!((PlayerGetPropertyInt(UnitGetOwner(EventUnit()), c_playerPropMinerals) >= 2000))) {
            return false;
        }

        if (!(((UnitGetType(EventUnit()) == "InfestedStukov") || (UnitGetType(EventUnit()) == "QueenMP")))) {
            return false;
        }

        if (!((libNtve_gf_UnitInRegion(EventUnit(), RegionFromId(78)) == true))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    gf_ClearRegionOfStatic(RegionFromId(77));
    PlayerModifyPropertyInt(UnitGetOwner(EventUnit()), c_playerPropMinerals, c_playerPropOperSubtract, 2000);
    libNtve_gf_CreateUnitsWithDefaultFacing(1, "LastBridgecaptured", c_unitCreateIgnorePlacement, EventPlayer(), PointFromId(1561906140));
    gv_lastBridgeActivated = true;
    gv_lastBridgeCaptured = UnitLastCreated();
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(110894555));
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(865279726));
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(2023334304));
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(2012584399));
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(686675918));
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(168418474));
    UIDisplayMessage(PlayerGroupAll(), c_messageAreaSubtitle, StringExternal("Param/Value/EBB9D68B"));
    UnitKill(gv_lastBridgeBeaconcaptured);
    SoundPlayForPlayer(SoundLink("Eventtriggering", -1), c_maxPlayers, PlayerGroupAll(), 75.0, 0.0);
    TriggerEnable(gt_LastBridgeCaptured, true);
    TriggerEnable(TriggerGetCurrent(), false);
    return true;
}

