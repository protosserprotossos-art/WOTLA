    if ((UnitIsAlive(UnitFromId(1213833690)) == false)) {
        gf_Createunit(1, "RoguePurifierSupportDroneA", lv_spawner, lv_point);
    }

    if ((UnitIsAlive(UnitFromId(1067839632)) == false)) {
        gf_Createunit(1, "RoguePurifierSupportDroneA", lv_spawner, lv_point);
    }

    if ((UnitIsAlive(UnitFromId(650634245)) == false)) {
        gf_Createunit(1, "Spectre", lv_spawner, lv_point);
    }

    if ((UnitIsAlive(UnitFromId(1087886462)) == false)) {
        gf_Createunit(1, "Spectre", lv_spawner, lv_point);
    }

    if ((UnitIsAlive(UnitFromId(573473263)) == false)) {
