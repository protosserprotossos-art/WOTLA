//--------------------------------------------------------------------------------------------------
// Trigger: Start Invasion
//--------------------------------------------------------------------------------------------------
bool gt_StartInvasion_Func (bool testConds, bool runActions) {
    // Automatic Variable Declarations
    unitgroup autoE37EDA5C_g;
    int autoE37EDA5C_u;
    unit autoE37EDA5C_var;

    // Actions
    if (!runActions) {
        return true;
    }

    if ((UnitIsAlive(UnitFromId(761806837)) == true)) {
        Wait(20.0, c_timeGame);
        UIDisplayMessage(PlayerGroupAll(), c_messageAreaSubtitle, StringExternal("Param/Value/1E4BE363"));
    }

    if ((UnitIsAlive(gv_dunharrowCaptured) == true)) {
        Wait(20.0, c_timeGame);
        UIDisplayMessage(PlayerGroupAll(), c_messageAreaSubtitle, StringExternal("Param/Value/488117E7"));
    }

    while ((UnitIsAlive(gv_calenardhonInvasionHero) == true)) {
        Wait(5.0, c_timeGame);
        autoE37EDA5C_g = gv_invasionGroup;
        autoE37EDA5C_u = UnitGroupCount(autoE37EDA5C_g, c_unitCountAll);
        for (;; autoE37EDA5C_u -= 1) {
            autoE37EDA5C_var = UnitGroupUnitFromEnd(autoE37EDA5C_g, autoE37EDA5C_u);
            if (autoE37EDA5C_var == null) { break; }
            UnitIssueOrder(autoE37EDA5C_var, OrderTargetingPoint(AbilityCommand("attack", 0), PointFromId(675482289)), c_orderQueueReplace);
        }
    }
    return true;
}

