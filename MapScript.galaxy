    UnitBehaviorRemove(gv_mirkwoodCreep2, "HeroDeathPrevention", 1);
    UnitBehaviorRemove(gv_mirkwoodCreep3, "HeroDeathPrevention", 1);
    UnitBehaviorRemove(gv_mirkwoodCreep4, "HeroDeathPrevention", 1);
    return true;
}

