//--------------------------------------------------------------------------------------------------
// Trigger: Activate Nurn
//--------------------------------------------------------------------------------------------------
bool gt_ActivateNurn_Func (bool testConds, bool runActions) {
    // Automatic Variable Declarations
    // Conditions
    if (testConds) {
        if (!((PlayerGetPropertyInt(UnitGetOwner(EventUnit()), c_playerPropMinerals) >= 5500))) {
            return false;
        }

        if (!(((UnitGetType(EventUnit()) == "TychusCommando") || (UnitGetType(EventUnit()) == "RaynorCommando")))) {
            return false;
        }

        if (!((libNtve_gf_UnitInRegion(EventUnit(), RegionFromId(73)) == true))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    gf_ClearRegionOfStatic(RegionFromId(74));
    PlayerModifyPropertyInt(UnitGetOwner(EventUnit()), c_playerPropMinerals, c_playerPropOperSubtract, 5500);
    libNtve_gf_CreateUnitsWithDefaultFacing(1, "NurnGood", c_unitCreateIgnorePlacement, EventPlayer(), PointFromId(1886691717));
    gv_nurn = UnitLastCreated();
    gv_nurnActivated = true;
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(1674838129));
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(1543768877));
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(635880955));
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(1915691732));
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(1963164148));
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(1005851882));
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(308428447));
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(1820484911));
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(1609039061));
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(1786824897));
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(1022040344));
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(1590378189));
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(1372573134));
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(955022622));
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(1677732381));
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(927572921));
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(442955467));
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(1915764218));
    gf_CreateCannon(UnitGetOwner(EventUnit()), PointFromId(1815976015));
    UIDisplayMessage(PlayerGroupAll(), c_messageAreaSubtitle, StringExternal("Param/Value/7986ECA9"));
    UnitKill(gv_nurnBeacon);
    SoundPlayForPlayer(SoundLink("Eventtriggering", -1), c_maxPlayers, PlayerGroupAll(), 75.0, 0.0);
    TriggerEnable(gt_NurnGood, true);
    TriggerEnable(TriggerGetCurrent(), false);
    return true;
}

