    if ((TechTreeUpgradeCount(UnitGetOwner(lv_spawner), "EdhelionUpgradespawn", c_techCountCompleteOnly) == 1)) {
        gf_Createunit(1, "Stalker", lv_spawner, lv_point);
        gf_Createunit(1, "Hellion", lv_spawner, lv_point);
    }

    return true;
}

