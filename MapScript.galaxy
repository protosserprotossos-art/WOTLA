//--------------------------------------------------------------------------------------------------
// Trigger: Calenardhon
//--------------------------------------------------------------------------------------------------
bool gt_Calenardhon_Func (bool testConds, bool runActions) {
    // Variable Declarations
    unit lv_spawner;
    point lv_point;
    string lv_research;

    // Automatic Variable Declarations
    // Variable Initialization
    lv_spawner = gv_calenardhon;
    lv_point = PointFromId(309666194);
    lv_research = "CalenardhonUpgradeSpawn";

    // Conditions
    if (testConds) {
        if (!((UnitIsAlive(lv_spawner) == true))) {
            return false;
        }

        if (!((PlayerGetPropertyInt(UnitGetOwner(lv_spawner), c_playerPropSuppliesUsed) <= PlayerGetPropertyInt(UnitGetOwner(lv_spawner), c_playerPropSuppliesMade)))) {
            return false;
        }

        if (!((UnitGetOwner(lv_spawner) != 0))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    if ((gf_OwnerOfUnitIsInGood(lv_spawner) == true)) {
        Wait(0.25, c_timeGame);
        gf_Createunit(2, "Vulture", lv_spawner, lv_point);
        gf_Createunit(2, "PreserverA", lv_spawner, lv_point);
        if ((TechTreeUpgradeCount(UnitGetOwner(lv_spawner), lv_research, c_techCountCompleteOnly) >= 4)) {
            gf_Createunit(1, "Zealot", lv_spawner, lv_point);
            gf_Createunit(1, "Marine", lv_spawner, lv_point);
            gf_Createunit(1, "PreserverA", lv_spawner, lv_point);
            gf_Createunit(1, "Vulture", lv_spawner, lv_point);
        }

        if ((TechTreeUpgradeCount(UnitGetOwner(lv_spawner), lv_research, c_techCountCompleteOnly) >= 3)) {
            gf_Createunit(1, "Zealot", lv_spawner, lv_point);
            gf_Createunit(1, "Marine", lv_spawner, lv_point);
            gf_Createunit(1, "PreserverC", lv_spawner, lv_point);
        }

        if ((TechTreeUpgradeCount(UnitGetOwner(lv_spawner), lv_research, c_techCountCompleteOnly) >= 2)) {
            gf_Createunit(1, "Vulture", lv_spawner, lv_point);
            gf_Createunit(1, "Marine", lv_spawner, lv_point);
            gf_Createunit(1, "PreserverB", lv_spawner, lv_point);
        }

        if ((TechTreeUpgradeCount(UnitGetOwner(lv_spawner), lv_research, c_techCountCompleteOnly) >= 1)) {
            gf_Createunit(1, "Vulture", lv_spawner, lv_point);
            gf_Createunit(1, "Zealot", lv_spawner, lv_point);
            gf_Createunit(1, "PreserverA", lv_spawner, lv_point);
        }

    }
    else if ((gf_OwnerOfUnitIsInEvil(lv_spawner) == true)) {
        Wait(0.25, c_timeGame);
        gf_Createunit(1, "MengskDiamondback", lv_spawner, lv_point);
        gf_Createunit(2, "PreserverA", lv_spawner, lv_point);
        if ((TechTreeUpgradeCount(UnitGetOwner(lv_spawner), lv_research, c_techCountCompleteOnly) >= 4)) {
            gf_Createunit(1, "Zealot", lv_spawner, lv_point);
            gf_Createunit(1, "Marine", lv_spawner, lv_point);
            gf_Createunit(1, "PreserverA", lv_spawner, lv_point);
            gf_Createunit(1, "ImmortalTaldarim", lv_spawner, lv_point);
        }

        if ((TechTreeUpgradeCount(UnitGetOwner(lv_spawner), lv_research, c_techCountCompleteOnly) >= 3)) {
            gf_Createunit(1, "Zealot", lv_spawner, lv_point);
            gf_Createunit(1, "Marine", lv_spawner, lv_point);
            gf_Createunit(1, "PreserverC", lv_spawner, lv_point);
        }

        if ((TechTreeUpgradeCount(UnitGetOwner(lv_spawner), lv_research, c_techCountCompleteOnly) >= 2)) {
            gf_Createunit(1, "MengskDiamondback", lv_spawner, lv_point);
            gf_Createunit(1, "Marine", lv_spawner, lv_point);
            gf_Createunit(1, "PreserverB", lv_spawner, lv_point);
        }

        if ((TechTreeUpgradeCount(UnitGetOwner(lv_spawner), lv_research, c_techCountCompleteOnly) >= 1)) {
            gf_Createunit(1, "MengskDiamondback", lv_spawner, lv_point);
            gf_Createunit(1, "Zealot", lv_spawner, lv_point);
            gf_Createunit(1, "PreserverA", lv_spawner, lv_point);
        }

    }
    return true;
}

