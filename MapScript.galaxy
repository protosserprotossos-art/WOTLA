    gt_DaleCaptured = TriggerCreate("gt_DaleCaptured_Func");
    TriggerEnable(gt_DaleCaptured, false);
    TriggerAddEventTimePeriodic(gt_DaleCaptured, 90.0, c_timeGame);
}

