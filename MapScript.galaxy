//--------------------------------------------------------------------------------------------------
// Trigger: Northman Settlement Activate
//--------------------------------------------------------------------------------------------------
bool gt_NorthmanSettlementActivate_Func (bool testConds, bool runActions) {
    // Variable Declarations
    unit lv_amonLanc;
    int lv_targetPlayer;
    int lv_index;

    // Automatic Variable Declarations
    const int auto4E0588DE_ae = 8;
    const int auto4E0588DE_ai = 1;

    // Variable Initialization
    lv_amonLanc = UnitFromId(969977804);

    // Conditions
    if (testConds) {
        if (!((TechTreeUpgradeCount(UnitGetOwner(lv_amonLanc), "InviteHumanSettlers", c_techCountCompleteOnly) == 1))) {
            return false;
        }

        if (!((EventPlayer() == UnitGetOwner(lv_amonLanc)))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    if ((gv_factionIsOnNorthmen == true)) {
        lv_targetPlayer = gv_itemNorthmen;
    }
    else {
        lv_targetPlayer = gv_itemEastGondor;
    }
    libNtve_gf_CreateUnitsWithDefaultFacing(1, "BarracksTechReactor", c_unitCreateIgnorePlacement, lv_targetPlayer, PointFromId(949795679));
    gv_northmanSettlement = UnitLastCreated();
    lv_index = 1;
    for ( ; ( (auto4E0588DE_ai >= 0 && lv_index <= auto4E0588DE_ae) || (auto4E0588DE_ai < 0 && lv_index >= auto4E0588DE_ae) ) ; lv_index += auto4E0588DE_ai ) {
        gf_CreateCannon(lv_targetPlayer, PointFromName(("AmonLancNorthmanCannon" + IntToString(lv_index))));
    }
    SoundPlayForPlayer(SoundLink("Eventtriggering", -1), c_maxPlayers, PlayerGroupAll(), 75.0, 0.0);
    UIDisplayMessage(PlayerGroupAll(), c_messageAreaSubtitle, StringExternal("Param/Value/5BC2C5D7"));
    TriggerEnable(gt_NorthmanSettlementSpawn, true);
    TriggerEnable(TriggerGetCurrent(), false);
    return true;
}

